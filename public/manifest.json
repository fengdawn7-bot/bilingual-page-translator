{
  "manifest_version": 3,
  "name": "Bilingual Page Translator",
  "description": "Translate ordinary web pages into bilingual Chinese with an OpenAI-compatible API.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Bilingual Translator",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
